---
import Layout from '../layouts/Layout.astro';
import { products } from '../data/products.js';
---

<Layout title="MasTomo | Produk Best Seller">
  <main class="w-full max-w-md bg-gradient-to-b from-slate-900 via-blue-950 to-slate-900 min-h-screen flex flex-col justify-between px-6 py-8 shadow-2xl border-x border-slate-800">
    
    <div class="flex flex-col items-center text-center mt-4">
      <div class="w-20 h-20 bg-zinc-300 rounded-full border-2 border-blue-500 overflow-hidden shadow-md flex items-center justify-center">
        <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=150" alt="MasTomo Profile" class="w-full h-full object-cover" />
      </div>
      
      <h1 class="mt-3 text-sm font-normal tracking-wide text-zinc-300">@MasTomo</h1>
      <h2 class="mt-2 text-sm font-bold tracking-wider text-blue-400 bg-blue-950/50 px-4 py-1 rounded-full border border-blue-900/50">
        PRODUK BEST SELLER
      </h2>
    </div>

    <div class="my-6 flex-grow flex flex-col justify-center">
      <div class="w-full bg-cyan-50/5 backdrop-blur-sm rounded-xl border border-blue-500/30 p-4 shadow-inner space-y-2 max-h-[60vh] overflow-y-auto">
        
        {products.map((product) => (
          /* 5 & 7. Link mengarah ke Bridge Page dinamis, bukan langsung ke Shopee */
          <a 
            href={`/go/${product.id}`} 
            class="flex items-stretch w-full rounded-lg border border-slate-700 bg-slate-800/80 hover:bg-slate-700/50 hover:border-blue-500 transition-all duration-200 group overflow-hidden"
          >
            <div class="w-12 bg-slate-700 group-hover:bg-blue-600 flex items-center justify-center text-xs font-bold text-zinc-100 border-r border-slate-600 transition-colors">
              {product.no}
            </div>
            <div class="flex-1 p-3 flex items-center text-left text-xs font-medium text-zinc-200 group-hover:text-white transition-colors">
              {product.name}
            </div>
            <div class="px-3 flex items-center text-slate-500 group-hover:text-blue-400 text-xs transition-colors">
              ➔
            </div>
          </a>
        ))}

      </div>

      <div class="w-full mt-4 p-4 bg-cyan-50/5 backdrop-blur-sm rounded-xl border border-blue-500/20 text-center">
        <p class="text-xs text-zinc-400 leading-relaxed">
          Klik pada salah satu produk di atas untuk langsung diarahkan ke halaman diskon Shopee Toko resmi.
        </p>
      </div>
    </div>

    <footer class="flex flex-col items-center text-center mb-2 pt-4 border-t border-slate-800/60">
      <div class="w-14 h-14 bg-zinc-400 rounded-full border border-slate-600 overflow-hidden shadow-inner mb-2">
        <img src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=100" alt="Footer Stamp" class="w-full h-full object-cover grayscale opacity-75" />
      </div>
      <p class="text-[10px] text-zinc-500 tracking-widest uppercase">© 2026 MasTomo Affiliate. All Rights Reserved.</p>
    </footer>

  </main>
</Layout>
